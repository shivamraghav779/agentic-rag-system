# ------------------------------------------------------------
# Copy to `.env` and fill in your values.
# ------------------------------------------------------------

# Database Configuration
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/chatbot

# Gemini API Keys (5 keys recommended for fallback)
# Option 1: single key (deprecated by code, but still supported)
# GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEYS=key1,key2,key3

# Groq API Keys (Fallback provider)
GROQ_API_KEYS=groq_key1,groq_key2
GROQ_MODEL=llama-3.3-70b-versatile

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# LLM Configuration
TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=2048

# Retrieval Configuration
RETRIEVAL_K=4
SOURCE_DOC_PREVIEW_LENGTH=500

# Prompt Configuration
DEFAULT_INSTRUCTION_PROMPT=Please provide a comprehensive answer based on the context provided. If the context doesn't contain enough information to answer the question, say so clearly. Use the context to provide accurate and relevant information.

# JWT Authentication
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_PER_MINUTE=60
CHAT_STREAM_RATE_LIMIT_PER_MINUTE=30

# SQLAlchemy connection pooling tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30

# File Upload
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./vector_stores
SQLITE_STORE_DIR=./sqlite_stores
ARTIFACTS_BASE_DIR=./artifacts

# Upload validation (bytes)
MAX_FILE_SIZE=10485760

# Chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKING_STRATEGY=recursive
MIN_CHUNK_SIZE_CHARS=150
MAX_CHUNKS_PER_DOCUMENT=2000

# Context budget (prevents prompt overflow)
CONTEXT_MAX_CHARS=12000
CONTEXT_MAX_DOC_CHARS=3000

# Robustness
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2

# Provider selection (for future Pinecone/vector DBs)
EMBEDDINGS_PROVIDER=gemini
VECTOR_DB_PROVIDER=faiss

# Caching (in-memory, per process)
ENABLE_VECTOR_STORE_CACHE=true
VECTOR_STORE_CACHE_SIZE=8
ENABLE_LLM_PROMPT_CACHE=true
LLM_PROMPT_CACHE_TTL_SECONDS=3600
LLM_PROMPT_CACHE_MAX_ENTRIES=1024
LLM_PROMPT_CACHE_MAX_PROMPT_CHARS=2000

# Celery + Redis (durable background jobs)
ENABLE_CELERY_TASKS=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# RAG toggles
ENABLE_QUERY_REWRITING=true
ENABLE_QUERY_EXPANSION=true
ENABLE_RERANKING=true
ENABLE_PROMPT_COMPRESSION=true
ENABLE_GROUNDING_CHECK=true

# Reranking / Compression
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
COMPRESSION_RATIO=0.7

# Grounding verification
GROUNDING_MAX_OUTPUT_TOKENS=256

